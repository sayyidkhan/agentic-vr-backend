APP_NAME=SceneVerse AI Backend
SCENEVERSE_PROFILE=local
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
MODEL_REGISTRY_PATH=app/data/enabled_models.json
VOICE_REGISTRY_PATH=app/data/voice_registry.json
ENABLE_LIVE_SCENE_ANALYSIS=false
SCENE_ANALYSIS_MODEL_ID=global.anthropic.claude-sonnet-4-6
ENABLE_EXA_CHARACTER_ENRICHMENT=true
SCENE_ANALYSIS_MAX_CHARACTERS=4
ENABLE_LIVE_CHARACTER_CHAT=false
CHARACTER_CHAT_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Optional integrations.
OPENAI_API_KEY=
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_TOKEN_TTL_SECONDS=600
OPENAI_REALTIME_VAD_THRESHOLD=0.5
OPENAI_REALTIME_VAD_PREFIX_PADDING_MS=300
OPENAI_REALTIME_VAD_SILENCE_DURATION_MS=800
SPEECHMATICS_API_KEY=
SPEECHMATICS_TTS_OUTPUT_FORMAT=wav_16000
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
EXA_API_KEY=

# Optional yt-dlp settings for YouTube downloads.
# Store exported YouTube cookies outside git. On EC2, use:
# YTDLP_COOKIES_FILE=/opt/sceneverse-config/youtube-cookies.txt
YTDLP_COOKIES_FILE=
YTDLP_USER_AGENT=
YTDLP_POT_PROVIDER_BASE_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=sgd
STRIPE_UNLOCK_AMOUNT_CENTS=500
FRONTEND_URL=http://localhost:5173
AWS_REGION=us-east-1

# Storage profiles. Change only SCENEVERSE_PROFILE for normal switching.
# local -> local SQLite + local media files
LOCAL_DATABASE_URL=sqlite:///./data/sceneverse-local.db
LOCAL_MEDIA_LOCAL_DIR=./data/media-local
LOCAL_MEDIA_PUBLIC_PATH=/media
LOCAL_MEDIA_STORAGE_PREFIX=videos

# cloud -> private RDS Postgres + S3/CloudFront media.
# Usually set this only on the EC2 host; local laptops should use the cloud API
# through the frontend proxy instead of connecting to private RDS directly.
CLOUD_DATABASE_URL=postgresql+psycopg://sceneverse:<password>@<rds-endpoint>:5432/sceneverse
CLOUD_MEDIA_STORAGE_PREFIX=videos
CLOUD_S3_VIDEO_BUCKET=
CLOUD_MEDIA_CDN_BASE_URL=

# Legacy unprefixed values are still accepted as fallback inputs.
DATABASE_URL=sqlite:///./data/sceneverse.db
MEDIA_LOCAL_DIR=./data/media
MEDIA_PUBLIC_PATH=/media
MEDIA_STORAGE_PREFIX=videos
S3_VIDEO_BUCKET=
MEDIA_CDN_BASE_URL=

# Local-only Bedrock API key path.
# AWS docs support using a Bedrock bearer token through this environment variable.
# For deployed EC2, prefer an instance IAM role instead of storing this secret on-server.
AWS_BEARER_TOKEN_BEDROCK=
